{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "share": "disabled",
  "autoupdate": true,
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-chat": {},
        "deepseek-reasoner": {
          "options": {
            "timeout": 180000
          }
        },
        "deepseek-v4-pro": {
          "options": {
            "timeout": 240000
          },
          "variants": {
            "none": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "variants": {
            "none": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b-64k": {
          "tools": true
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "qwen/qwen3-vl-235b-a22b-instruct": {
          "name": "Qwen3-VL 235B (vision)"
        }
      }
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
